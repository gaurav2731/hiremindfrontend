# ─── API Base URL ────────────────────────────────────────────────────────
# In development, Vite proxies /api → localhost:8000 (see vite.config.js).
# In production (separate frontend/backend deploys on Vercel), set this to
# your backend's deployed URL.
#
# Examples:
#   VITE_API_URL=http://localhost:8000      (local backend)
#   VITE_API_URL=https://your-backend.vercel.app  (Vercel production)
#
# If unset, defaults to '/api' (same-origin).

VITE_API_URL=
