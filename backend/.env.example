# ─── Database ────────────────────────────────────────────────────────────
# Local dev: SQLite (default, no setup needed)
# Production (Vercel): PostgreSQL via Neon or Supabase
DATABASE_URL=sqlite:///./hiremind.db

# Direct (non-pooled) connection for schema migrations.
# Required when DATABASE_URL points to a connection pooler (Neon/Supabase).
# For Neon: set to the non-pooled connection string (no -pooler suffix)
# For Supabase: set to port 5432 direct connection
DIRECT_URL=

# Connection pool recycle time in seconds (default 300 = 5 min)
DB_POOL_RECYCLE=300

# ─── AI / LLM ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Optional: set to https://openrouter.ai/api/v1 to use OpenRouter
LLM_BASE_URL=

# ─── Auth / JWT ─────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-change-me
JWT_ALGORITHM=HS256
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Frontend ────────────────────────────────────────────────────────────
# Local dev: http://localhost:5173
# Production: https://your-frontend.vercel.app
FRONTEND_ORIGIN=http://localhost:5173
